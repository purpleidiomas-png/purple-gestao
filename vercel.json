{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {"source": "/alunos", "destination": "/index.html"},
    {"source": "/dashboard", "destination": "/index.html"},
    {"source": "/financeiro", "destination": "/index.html"},
    {"source": "/relatorios", "destination": "/index.html"}
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key":"X-Content-Type-Options","value":"nosniff"},
        {"key":"X-Frame-Options","value":"SAMEORIGIN"},
        {"key":"Referrer-Policy","value":"strict-origin-when-cross-origin"}
      ]
    }
  ]
}
